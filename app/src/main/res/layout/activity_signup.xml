<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#050526"
    tools:context=".Signup">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text=" ✨ Signup ✨"
        android:textSize="38sp"
        android:fontFamily="times new roman"
        android:textAlignment="center"
        android:textStyle="bold|italic"
        android:background="@drawable/shape"
        android:padding="12dp"
        android:textColor="#EDEDED"/>

    <!--    Below is a cardview -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="12dp"
        app:cardElevation="10dp"
        android:layout_margin="12dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:background="#5F5852"
            android:padding="12dp">

            <!--            Below is the editText for username -->
            <EditText
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="👤  Enter your Username"
                android:textColorHint="#000"
                android:textSize="22sp"
                android:fontFamily="times new roman"
                android:textColor="#000"
                android:id="@+id/username"
                android:layout_margin="8dp"
                android:background="#F8F6F6"
                android:padding="10dp" />

            <!--            Below is the editText for email -->
            <EditText
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="📧  Enter your Email Address"
                android:textColorHint="#000"
                android:textSize="22sp"
                android:fontFamily="times new roman"
                android:textColor="#000"
                android:id="@+id/email"
                android:inputType="textEmailAddress"
                android:layout_margin="8dp"
                android:background="#F8F6F6"
                android:padding="10dp" />

            <!--            Below is the editText for password -->
            <EditText
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="🔑  Enter your password"
                android:textColorHint="#000"
                android:textSize="22sp"
                android:textColor="#000"
                android:fontFamily="times new roman"
                android:id="@+id/password"
                android:inputType="textPassword"
                android:layout_margin="8dp"
                android:background="#F8F6F6"
                android:padding="10dp" />

            <!--            Below is the editText for Phone number -->
            <EditText
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="📞  Enter your Phone Number"
                android:textColorHint="#000"
                android:textSize="22sp"
                android:textColor="#000"
                android:fontFamily="times new roman"
                android:id="@+id/phone"
                android:inputType="number"
                android:layout_margin="8dp"
                android:background="#F8F6F6"
                android:padding="10dp" />

            <!--            Below is the signup Button -->
            <Button
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="👤 Signup"
                android:textSize="25sp"
                android:padding="10dp"
                android:textStyle="bold"
                android:layout_marginLeft="50dp"
                android:layout_marginRight="50dp"
                android:fontFamily="times new roman"
                android:layout_marginTop="25dp"
                android:textColor="#060606"
                android:backgroundTint="#2bd706"
                android:id="@+id/signupBtn" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Already Have an Accout? Signin"
                android:textAlignment="center"
                android:fontFamily="times new roman"
                android:textSize="23sp"
                android:layout_marginTop="25dp"
                android:textColor="#0013e9"
                android:id="@+id/signintxt" />


        </LinearLayout>

    </androidx.cardview.widget.CardView>



</LinearLayout>