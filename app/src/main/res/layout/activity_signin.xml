<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#678"
    android:orientation="vertical"
    tools:context=".Signin">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="❇️Sign In❇️"
        android:textSize="32sp"
        android:textAlignment="center"
        android:textStyle="italic|bold"
        android:fontFamily="cursive"
        android:textColor="#101010"
        android:background="@drawable/shape"
        />
<!--    Below is a card -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="10dp"
        android:layout_margin="8dp"
        app:cardElevation="10dp"
        android:padding="10dp">

<!--       Below is a linearlayout that will align content vertically -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:background="#f9ba7a"
            android:padding="10dp">

<!--        Below is the email editText-->
            <EditText
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="📧 Enter Email Adress"
                android:textColorHint="#000000"
                android:id="@+id/email"
                android:fontFamily="times new roman"
                android:layout_margin="8dp"
                android:padding="11dp"
                android:background="#f99c9b" />

            <!--        Below is the password editText-->
            <EditText
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="🔑 Enter Your Password"
                android:textColorHint="#000000"
                android:id="@+id/password"
                android:fontFamily="times new roman"
                android:layout_margin="8dp"
                android:padding="11dp"
                android:background="#f99c9b"
                 />

<!--          Below is the sign in bbutton  -->
            <Button
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Sign In ➡️"
                android:textSize="25sp"
                android:padding="10dp"
                android:textStyle="bold"
                android:fontFamily="times new roman"
                android:layout_marginLeft="50dp"
                android:layout_marginRight="50dp"
                android:layout_marginTop="18dp"
                android:textColor="#010112"
                android:backgroundTint="#d6f011"
                android:id="@+id/signinBtn"
                />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Dont have an account? Sign Up"
                android:textAlignment="center"
                android:textStyle="italic"
                android:fontFamily="times new roman"
                android:textColor="#1854a4"
                android:textSize="24sp"
                android:id="@+id/signuptxt"
                android:layout_marginTop="25dp"/>

        </LinearLayout>

    </androidx.cardview.widget.CardView>

</LinearLayout>