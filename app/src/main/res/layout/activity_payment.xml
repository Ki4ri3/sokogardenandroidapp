<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#fff"
    tools:context=".payment">

<!--    Below is a text view-->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Complete Payment with M-Pesa"
        android:textSize="32sp"
        android:textColor="#121212"
        android:textAlignment="center"
        android:layout_marginTop="8dp"
        android:textStyle="bold"
        android:fontFamily="times new roman"
        android:background="#1d8b02"/>

<!--    Below is a cardview that holds all our content-->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="10dp"
        app:cardElevation="12dp"
        app:cardCornerRadius="14dp"
        >

<!--        Below is the linear layout -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:padding="12dp"
            android:background="#021834">

<!--            Below is a text view where the product name shall be attached-->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Product Name"
                android:textSize="28sp"
                android:textAlignment="center"
                android:fontFamily="times new roman"
                android:textColor="#f9f0f2"
                android:id="@+id/txtProductName"
                />
<!--            Below is an image view for the product photo-->
            <ImageView
                android:layout_width="match_parent"
                android:layout_height="300dp"
                android:id="@+id/imgProduct"
                android:src="@drawable/homebanner"
                android:scaleType="fitXY"
                android:layout_marginTop="4dp"
                android:layout_marginLeft="20dp"
                android:layout_marginRight="20dp"
                />
 <!--            Below is a text view where the product name shall be attached-->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="This is where the product description will appear."
                android:textSize="20sp"
                android:textAlignment="center"
                android:layout_marginTop="4dp"
                android:fontFamily="times new roman"
                android:textColor="#f9f0f2"
                android:id="@+id/txtProductDescription"
                />

<!--            below is the textview for the product cost-->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:id="@+id/txtProductCost"
                android:text="KSH 1000"
                android:textStyle="bold"
                android:fontFamily="times new roman"
                android:layout_marginTop="8dp"
                android:textAlignment="center"
                android:textSize="30sp"
                android:textColor="#f9f0f2"/>

<!--           below is the edittext for the client to enter the mobile number -->
            <EditText
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:id="@+id/phone"
                android:hint="Enter Phone Number (+2547xxxxxxxx)"
                android:textColorHint="#000"
                android:textColor="#000"
                android:padding="15dp"
                android:layout_marginTop="8dp"
                android:background="#f9f0f2"/>

<!--            Below is the button to complete the payment action-->
            <Button
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:id="@+id/pay"
                android:text="Pay Now"
                android:textStyle="bold"
                android:fontFamily="times new roman"
                android:textSize="22sp"
                android:layout_marginTop="20dp"
                android:layout_marginRight="50dp"
                android:layout_marginLeft="50dp"
                android:backgroundTint="#1d8b02"/>



        </LinearLayout>

    </androidx.cardview.widget.CardView>

</LinearLayout>